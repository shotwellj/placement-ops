{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/market-intel",
      "destination": "/market-intel.html"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 300
    }
  }
}